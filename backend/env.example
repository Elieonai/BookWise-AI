# Chave de acesso à API da Gemini
# Gere a sua em: https://aistudio.google.com/app/api-keys
GEMINI_API_KEY=sua_chave_aqui

# Origens permitidas para acessar a API. Separe mais de uma por virgula.
# Em desenvolvimento, pode ficar vazio para permitir chamadas locais sem Origin.
FRONTEND_ORIGIN=http://localhost:5173

# Firebase Web SDK / Firestore
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# Firebase Admin SDK para scripts locais, como npm run seed:firestore.
# Opcao local recomendada: salve a service account em backend/credentials/serviceAccountKey.json.
GOOGLE_APPLICATION_CREDENTIALS=./credentials/serviceAccountKey.json

# Opcao alternativa para Render/CI: cole o JSON inteiro em uma variavel de ambiente.
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# Porta do servidor local. No Render, deixe sem configurar porque a plataforma injeta PORT.
PORT=3000
